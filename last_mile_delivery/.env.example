# Django
# Generate a fresh one for real use, e.g.:
# python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
SECRET_KEY=change-me-to-a-random-50-char-string
DEBUG=True

# Comma-separated list of allowed hosts. Required (non-empty) once DEBUG=False.
# Example for production: ALLOWED_HOSTS=api.yourdomain.com,yourdomain.com
ALLOWED_HOSTS=localhost,127.0.0.1

# Database (MySQL)
DB_NAME=last_mile_delivery
DB_USER=root
DB_PASSWORD=change-me
DB_HOST=localhost
DB_PORT=3306

# CORS (only relevant once django-cors-headers is added per the pending fix)
# Comma-separated list of frontend origins allowed to call this API.
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Email (optional — currently unused , present for future notifications)
# EMAIL_HOST=smtp.gmail.com
# EMAIL_PORT=587
# EMAIL_HOST_USER=your_email@gmail.com
# EMAIL_HOST_PASSWORD=your_app_password
